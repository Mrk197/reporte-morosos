{
  "name": "mikrowisp-scripts",
  "version": "1.0.0",
  "description": "Scripts utilitarios para MikroWisp API - DIGY",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "clientes-sin-pago": "tsx new-clients-unpaid.ts",
    "clientes-sin-pago:excel": "tsx new-clients-unpaid.ts --format excel",
    "clientes-sin-pago:csv": "tsx new-clients-unpaid.ts --format csv",
    "clientes-sin-pago:test": "tsx new-clients-unpaid.ts --test",
    "server": "tsx server.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/express": "^4.17.17"
  }
}
